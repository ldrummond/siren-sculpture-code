# Laptop-to-Pi sync defaults. These are not secrets; do not store passwords here.
PI_HOST=siren2.local
PI_USER=admin
SSH_PORT=22
APP_DIR=/opt/sculpture

# Default sync behavior for sync-to-pi.sh.
# RUN_INITIALIZE is for a fresh Pi; RUN_INSTALL is for normal code updates.
RUN_INITIALIZE=0
RUN_INSTALL=1
SYNC_AUDIO=1
